<!DOCTYPE html>
<html>
<head>
  <title>Marquee Admin</title>
  <meta name="turbo-visit-control" content="reload">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; margin: 0; padding: 0; color: #333; }
    .admin-header { background: #1a1a2e; color: #fff; padding: 12px 24px; display: flex; align-items: center; gap: 24px; }
    .admin-header a { color: #ccc; text-decoration: none; font-size: 14px; }
    .admin-header a:hover { color: #fff; }
    .admin-header .back-link { margin-right: 8px; padding-right: 16px; border-right: 1px solid #444; }
    .admin-header h1 { font-size: 18px; margin: 0; }
    .admin-content { padding: 24px; max-width: 1200px; }
    table { width: 100%; border-collapse: collapse; }
    th, td { text-align: left; padding: 10px 12px; border-bottom: 1px solid #e5e7eb; }
    th { background: #f9fafb; font-weight: 600; font-size: 13px; text-transform: uppercase; color: #6b7280; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: 600; }
    .badge-running { background: #d1fae5; color: #065f46; }
    .badge-draft { background: #e5e7eb; color: #374151; }
    .badge-paused { background: #fef3c7; color: #92400e; }
    .badge-completed { background: #dbeafe; color: #1e40af; }
  </style>
</head>
<body>
  <div class="admin-header">
    <%= link_to "← Back", main_app.root_path, class: "back-link" %>
    <h1>Marquee</h1>
    <%= link_to "Experiments", experiments_path %>
    <%= link_to "Funnels", funnels_path %>
    <%= link_to "Leads", admin_leads_path %>
    <%= link_to "Pages", pages_path %>
  </div>
  <div class="admin-content">
    <%= yield %>
  </div>
</body>
</html>
